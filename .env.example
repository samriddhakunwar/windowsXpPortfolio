# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Resend (email provider) ───────────────────────────────────────────────────
# Obtain from: https://resend.com/api-keys
# Required for the /api/contact endpoint.
# Keep this server-side only — do NOT prefix with NEXT_PUBLIC_.
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# ── Contact form ─────────────────────────────────────────────────────────────
# The email address that receives messages submitted via the contact form.
# Keep this server-side only — do NOT prefix with NEXT_PUBLIC_.
CONTACT_EMAIL=your.email@example.com
